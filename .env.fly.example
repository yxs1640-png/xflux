# =============================================================================
# Fly.io 部署环境变量参考（不要提交真实密钥）
# 完整步骤见 docs/DEPLOYMENT.md
# =============================================================================

# --- Fly app: xflux-api (cd api-server) ---
# fly secrets set CONSUMER_API_KEY="..." XFLUX_INTERNAL_KEY="..."
CONSUMER_API_KEY=
XFLUX_INTERNAL_KEY=
CONSUMER_API_BASE_URL=http://89.167.53.180
CONSUMER_API_PREFIX=/consumer

# --- Fly app: xflux-monitor-worker (repo root) ---
# fly secrets set DATABASE_URL="..." DIRECT_URL="..." CONSUMER_API_KEY="..." -a xflux-monitor-worker
# DATABASE_URL=postgresql://...6543...?pgbouncer=true
# DIRECT_URL=postgresql://...5432...
# MONITOR_WORKER_TICK_MS=30000
# MONITOR_WORKER_BATCH_SIZE=5

# --- Vercel (主站) ---
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXTAUTH_SECRET=
# XFLUX_API_SERVER_URL=https://xflux-api.fly.dev
# XFLUX_INTERNAL_KEY=same-as-fly-api-server
# 不要设置 CONSUMER_API_KEY
