# =============================================================================
# Supabase 连接配置
# 获取方式：项目首页顶部 → 点击 "Connect" 按钮（不是 Settings → Database）
# =============================================================================

# 方式 A — 你已有 DIRECT_URL（Project Overview 里看到的 5432 连接串）
# 本地开发：两个变量可以先填同一个值
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.xxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.xxxxx.supabase.co:5432/postgres"

# 方式 B — 从 DIRECT_URL 推导 DATABASE_URL（部署 Vercel 时用）
# 1. 打开 Connect → 选 "ORMs" 或 "Transaction pooler"
# 2. 复制端口 6543 的连接串，末尾加 ?pgbouncer=true
# DATABASE_URL="postgresql://postgres.xxxxx:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL 仍用 5432 直连

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Consumer Twitter API — 本地开发（根目录 .env 即可，无需单独启 api-server）
CONSUMER_API_BASE_URL="http://89.167.53.180"
CONSUMER_API_PREFIX="/consumer"
CONSUMER_API_KEY=""

# Fly.io + Vercel 生产 — 见 docs/DEPLOYMENT.md
# XFLUX_API_SERVER_URL="https://xflux-api.fly.dev"
# XFLUX_INTERNAL_KEY="same-as-fly-secrets"

# Optional — enable in-process monitor polling during `npm run dev`
# MONITOR_WORKER_ENABLED="true"
# MONITOR_WORKER_TICK_MS="30000"
# MONITOR_WORKER_BATCH_SIZE="5"

# Stripe — see docs/STRIPE.md
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_PRO=""
